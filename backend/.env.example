PORT=5000
MONGO_URI=mongodb://localhost:27017/framevault
FRONTEND_URL=http://localhost:5173,http://localhost:5174
API_PUBLIC_URL=http://localhost:5000

# AWS S3 + CloudFront (also accepts AWS_BUCKET_NAME and CLOUDFRONT_URL)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_S3_BUCKET=akhdmedia
AWS_BUCKET_NAME=akhdmedia
AWS_S3_PUBLIC_URL=https://cdn.akhdmedia.com
CLOUDFRONT_URL=https://cdn.akhdmedia.com
AWS_SIGNED_URL_EXPIRY=3600

# S3 folder layout (automatic):
#   delivery/master-videos/       — master original video
#   delivery/master-images/       — master original image
#   delivery/transcoded-videos/   — auto-generated Full HD+ tiers
#   storefront/preview-images/    — product preview gallery
#   storefront/demo-videos/       — storefront demo/preview video
#   storefront/video-posters/     — video poster thumbnail

# Install: https://ffmpeg.org/download.html
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_PRESET=medium
FFMPEG_CRF=18

# Email (order download links sent after purchase)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FrameVault <licensing@framevault.com>
